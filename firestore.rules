rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // 1. Users — any signed-in user can read; each user can write their own doc; admin can write any
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // role promotion done server-side via admin client
    }

    // 2. Events — all signed-in users can read & write
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 3. Complaints — all signed-in users can read & write
    match /complaints/{complaintId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 4. Careers — all signed-in users can read & write
    match /careers/{careerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 5. Fees — signed-in users can read; only owner can pay (update status)
    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // 6. Attendance (legacy geofence counter) — all signed-in users can read & write
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 7. Chat Channels — public read; signed-in users can seed / update
    match /chatChannels/{channelId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    // 8. Chat Messages — public read; signed-in users can post & react
    match /chatMessages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn()
                     && request.resource.data.content is string
                     && request.resource.data.content.size() > 0
                     && request.resource.data.content.size() <= 2000;
      allow update: if isSignedIn()
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['reactions', 'isPinned']);
    }

    // 9. Admins — read-only for signed-in users; never writable from client
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 10. Settings (institute config, campus coords) — signed-in users can read; admins write
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 11. Notices — all signed-in can read; admin/teacher can post
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 12. QR Sessions — teachers/admin create; all signed-in read;
    //     only the session owner (teacherUid) can update (end session)
    match /qrSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.teacherUid;
    }

    // 13. Attendance Records (QR) — students can create their own; all signed-in can read; immutable after write
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update: if false; // immutable once written
    }

    // 14. Clubs — all signed-in can read; admin manages presidents via write
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 15. Club Applications — students create own; all signed-in can read; president updates status
    match /clubApplications/{appId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update: if isSignedIn(); // president accepts/rejects
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

